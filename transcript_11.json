        },
        {
            "start": "0:08:10",
            "end": "0:08:40",
            "text": "\u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e\u0908 \u0935\u093e"
        },
        {
            "start": "0:08:40",
            "end": "0:08:44",
            "text": "\u092c\u0941\u0930\u094d\u0926\u0947\u0935, \u092e\u0947\u0930\u0947 \u0932\u093f\u090f \u0938\u0947 \u092d\u0940 \u0938\u0932\u0947\u0915 \u0915\u093f\u092f\u093e \u0939\u0948, \u0905\u091a\u094d\u091b\u0940 \u0924\u0917\u093e\u0930\u0940 \u0915\u0930\u0935\u093e\u0928\u093e"
        },
