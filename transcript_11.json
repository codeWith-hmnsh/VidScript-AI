        {
            "start": "0:00:09",
            "end": "0:00:10",
            "text": "\u0905\u091a \u0905\u091a, \u0905\u0916 \u0915\u094b\u091f \u092a\u0948\u0928 \u0930\u0939\u0947 \u0939\u0948\u0902."
        },
        {
            "start": "0:00:11",
            "end": "0:00:11",
            "text": "\u091c\u0940."
        },
        {
            "start": "0:00:12",
            "end": "0:00:13",
            "text": "\u092a\u0939\u0932\u0947 \u092f\u0947 \u092a\u0924\u093e \u0939\u0948, \u0905\u092c \u0939\u0948 \u0915\u094b\u0902?"
        },
        {
            "start": "0:00:14",
            "end": "0:00:17",
            "text": "\u091c\u0935\u093e\u0928 \u092e\u093f\u0932\u0915\u093e \u0938\u093f\u0902\u0917, \u092f\u0947 \u092e\u0940 \u0938\u0902\u091f\u0930\u0938 \u0915\u0902\u0926\u094d\u0930\u093e \u092c\u093e\u0926."
        },
        {
            "start": "0:00:17",
            "end": "0:00:17",
            "text": "\u0905\u091a \u0906\u0916."
        },
        {
            "start": "0:00:31",
            "end": "0:00:34",
            "text": "\u092f\u0947 \u092f\u0947 \u0905\u092c \u0932\u0947\u091c\u093c\u093e \u0930\u0939\u0947 \u0939\u0948\u0902, \u0939\u0948 \u0928\u093e?"
        },
        {
            "start": "0:00:35",
            "end": "0:00:36",
            "text": "\u0938\u092c \u0915\u094b \u0928\u0939\u0940\u0902 \u092e\u093f\u0932\u0924\u093e \u0939\u0948."
        },
        {
            "start": "0:00:37",
            "end": "0:00:39",
            "text": "\u0939\u092e\u0930\u0947 \u091c\u093e\u0938\u0947 \u0915\u0941\u091f \u091a\u093e\u092e\u092a\u093f\u092f\u0902\u091c \u0915\u094b \u092e\u093f\u0932\u0924\u093e \u0939\u0948."
        },
        {
            "start": "0:00:41",
            "end": "0:00:42",
            "text": "\u0924\u0940\u0915 \u0939\u0948?"
        },
        {
            "start": "0:00:43",
            "end": "0:00:45",
            "text": "\u091a\u0932\u093f, \u091c\u093e\u090f."
        },
        {
            "start": "0:00:46",
            "end": "0:00:47",
            "text": "\u092c\u093e\u0917\u093f\u090f?"
        },
        {
            "start": "0:00:49",
            "end": "0:00:51",
            "text": "\u091a\u0932\u093f, \u0932\u093f\u0915\u0932 \u092f\u0939\u093e \u0938\u0947."
        },
        {
            "start": "0:00:53",
            "end": "0:00:54",
            "text": "\u091a\u094b\u0932\u094b, \u0924\u0947\u0930\u0947 \u0915\u0930\u094b."
        },
        {
            "start": "0:00:55",
            "end": "0:00:56",
            "text": "\u091a\u094b\u0932\u0924\u0947 \u0938\u0947."
        },
        {
            "start": "0:01:00",
            "end": "0:01:03",
            "text": "\u092c\u093e\u0917\u093f\u090f, \u0930\u0939\u093e \u092c\u093e\u0917\u093f\u090f."
        },
        {
            "start": "0:02:00",
            "end": "0:02:10",
            "text": "\u0905\u0908, \u092f\u0947 \u0915\u094d\u092f\u093e \u0926\u0947\u0916 \u0930\u0939\u0947 \u0938\u093e \u0932\u0947, \u0935\u093f\u0938\u094d\u092e\u093e\u0930\u094d\u091f \u0938\u0926\u093e\u0930 \u091c\u0940,"
        },
        {
            "start": "0:02:17",
            "end": "0:02:23",
            "text": "\u092e\u093f\u0932\u0915\u094d\u092f\u093e \u092e\u0928\u094d\u0917\u0947 \u0905\u0926\u094d\u092f\u093e, \u092e\u093f\u0932\u0915\u094d\u092f\u093e \u092e\u0928\u094d\u0917\u093e \u091a\u0902\u092a\u094d\u092f\u0928,"
        },
        {
            "start": "0:02:24",
            "end": "0:02:31",
            "text": "\u0905\u0908, \u091a\u0902\u092a\u094d\u092f\u0928 \u092e\u093f\u0932\u0915\u093e \u0938\u0940\u0902 \u0930\u0939\u093e \u091c\u0940?"
        },
        {
            "start": "0:02:33",
            "end": "0:02:35",
            "text": "\u0915\u094d\u092f\u093e \u0939\u0948?"
        },
        {
            "start": "0:02:36",
            "end": "0:02:38",
            "text": "\u091a\u094b\u0930 \u0926\u0932\u093f\u0928 \u0924\u0930 \u0938\u093e\u0932\u0947, \u091a\u094b\u0930\u0940 \u0915\u0930 \u0930\u0939\u0947?"
        },
        {
            "start": "0:02:39",
            "end": "0:02:41",
            "text": "\u0935\u0942\u0928\u093e\u0908 \u091c\u0940, \u092e\u0948\u0902\u091f\u0947 \u0938\u092d \u092a\u094d\u092f\u0928\u0915\u0947 \u0924\u0947\u0916\u0930\u093e \u0925\u093e \u091c\u0940,"
        },
        {
            "start": "0:02:42",
            "end": "0:02:44",
            "text": "\u092a\u094d\u092f\u0928\u0915\u0947 \u0926\u0947\u0916\u0930\u093e \u0926\u094d\u092f\u093e\u0928, \u092c\u094d\u092f\u0928\u0915\u0947."
        },
        {
            "start": "0:02:45",
            "end": "0:02:49",
            "text": "\u091a\u094b\u0930 \u0938\u093e\u0932\u0947, \u0935\u094b\u0908, \u092e\u0941\u091c\u093c \u091a\u094b\u0930\u0928\u093e \u092c\u094b\u0932\u094b,"
        },
        {
            "start": "0:02:50",
            "end": "0:02:51",
            "text": "\u091a\u094b\u0930 \u0928\u0940 \u0924\u094b \u0914\u0930 \u0915\u094d\u092f\u093e \u0939\u0948?"
        },
        {
