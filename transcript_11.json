            "text": "\u092f\u0938 \u0938\u093e.."
        },
        {
            "start": "0:08:46",
            "end": "0:08:48",
            "text": "\u0924\u092c\u093e\u0936"
        },
        {
            "start": "0:08:50",
            "end": "0:08:55",
            "text": "\u0906\u092a \u0932\u093f\u090f, \u0907\u0930\u0935\u093e\u0930 \u092a\u0924\u094d\u091f\u0930 \u0906\u0928\u094d\u0928\u093e \u0935\u0921\u0921\u093e\u0928\u0940 \u0905\u0908\u0917\u093e \u0915\u093f \u0924\u0940\u0938\u0940 \u0915\u093f\u0928\u0926\u0930 \u092e\u0947\u0902 \u0906\u091c\u093e \u0939\u0948"
        },
