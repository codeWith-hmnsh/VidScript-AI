        },
        {
            "start": "0:04:04",
            "end": "0:04:06",
            "text": "\u0915\u094d\u092f\u094b \u092c\u093e\u092f\u093e \u0924\u0941\u0928 \u0924\u093e \u0915\u094b\u0908?"
