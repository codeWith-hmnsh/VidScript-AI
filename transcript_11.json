        },
        {
            "start": "0:04:09",
            "end": "0:04:10",
            "text": "\u0915\u094b\u0908 \u092a\u093e\u0928\u093e \u0924\u0941\u0928?"
        },
        {
            "start": "0:04:11",
            "end": "0:04:12",
            "text": "\u0907\u0902\u091f\u094d\u092f\u093e \u0924\u093e \u0915\u094b\u0908 \u092a\u093e\u0928\u093e?"
        },
        {
            "start": "0:04:14",
            "end": "0:04:15",
            "text": "\u0906\u0935\u0947 \u0928?"
        },
        {
            "start": "0:04:17",
            "end": "0:04:20",
            "text": "\u0906\u0935\u0947 \u0928\u0939\u0940\u0902 \u0928\u0939\u0940\u0902 \u0928\u0939\u0940\u0902 \u0932\u0921\u093c \u0905\u0902\u091f\u094d\u092f\u093e \u0915\u094b\u0908 \u0915\u092e\u093e\u0928\u093e \u092a\u0930\u0924\u093e \u0939\u0948!"
        },
        {
            "start": "0:04:20",
            "end": "0:04:22",
            "text": "\u092e\u0902\u0921 \u0915 ogs\u00e5 \u0915\u093e \u0920\u093f\u092f\u0947 \u092f\u094b \u0926\u094b\u0921 \u0928\u093e \u0939\u0942\u0901\u0901\u090c\u0901\u0901\u0901\u0901\u0901\u0909\u091f!"
        },
        {
            "start": "0:04:23",
            "end": "0:04:26",
            "text": "\u0935\u0922\u093c\u093f\u0938 \u0915\u094b \u0928\u0918\u094d\u0928\u093e\u0927\u093e\u0930 perfect for India!"
        },
        {
            "start": "0:04:28",
            "end": "0:04:28",
            "text": "\u092d\u0906\u0928\u093e \u0928\u0939\u0940\u0902 \u0932\u0917\u0915\u093e\u0928\u093e \u0914\u0917\u0920\u093e!"
        },
        {
            "start": "0:04:29",
            "end": "0:04:30",
            "text": "\u0928\u0939\u0940\u0902 \u0924\u093e \u0915\u094b\u0908 \u0905\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u0901\u090b\u0926!"
        },
        {
            "start": "0:04:30",
            "end": "0:04:33",
            "text": "\u092c\u0928\u093e \u0905\u0908 \u0916\u093c\u092b\u094d\u0928\u094b, \u0905\u090f\u0906, \u0939\u0948 candidates Lak."
        },
        {
            "start": "0:04:33",
            "end": "0:04:35",
            "text": "\u0905\u0906, \u091c\u093c\u092b \u092a\u0930\u0938\u0940 \u0936\u0930 \u091a\u093f\u0938\u094d\u091f\u0943\u0938\u094d\u0925 \u091a\u094d\ufffd oba."
        },
        {
            "start": "0:04:43",
            "end": "0:04:44",
            "text": "\u0905\u092b\u093f Lak."
        },
        {
            "start": "0:04:51",
            "end": "0:04:53",
            "text": "\u0914\u093c \u0907\u0930, \u0909\u0917\u0947\u0964 \u092e\u094b YouTuber Grandma is expecting.."
        },
        {
            "start": "0:04:53",
            "end": "0:04:55",
            "text": "\u0914\u0930 \u0914\u0930 \u0935\u0902\u0937\u093e\u0902\u0940\u0915\u091e\u093e \u0936\u0941\u0908 \u0908\u0928, \u0914\u0930 \u0938\u094d\u092c\u092e\u094d\u0928\u093e \u090f\u0915 \u0920\u0939\u0940 \u0915\u0947 \u0910\u0901\u0964\uc5c8\ub358\u0909 ba\u015fka l presidente O skills?"
        },
        {
            "start": "0:04:55",
            "end": "0:04:55",
            "text": "resposta Yasta."
        },
        {
            "start": "0:04:55",
            "end": "0:05:03",
            "text": "\u0926\u092e \u0906\u092a\u093f\u0930 \u092e\u0947\u0902\u0917\u093e \u091a\u0940\u0930 \u0938\u093f\u0917\u094d\u0930\u093e\u0928\u093e \u0915\u094b\u0930\u093e\u0928\u0947 \u0915\u093e\u0930\u093e \u090f\u0915 \u092c\u094b\u0932\u0947\u0917\u0902 \u0926\u094b\u0921\u093c\u093e \u092e\u0947\u0902\u0917\u093e \u0914\u091c\u0940"
        },
        {
            "start": "0:05:09",
            "end": "0:05:15",
            "text": "\u0907\u091a\u0935\u0948 \u0924\u094b \u0916\u0932 \u092d\u0940 \u0939\u0930\u093e \u0938\u0915\u094d\u0921\u093e\u090f. \u092e\u0948\u091d \u0926\u0928 \u0915\u0941\u0932\u093e \u0939\u0948. \u0905\u091a\u0940."
        },
        {
            "start": "0:05:15",
            "end": "0:05:20",
            "text": "\u0924\u094b \u0915\u0932 \u092d\u0940 \u0939\u0930\u093e \u0938\u0915\u0924\u093e \u0939\u0948, \u092e\u0948\u0926\u0928 \u0916\u0941\u0932\u093e \u0939\u0948, \u091a\u0942\u091f\u0940\u0964"
        },
        {
            "start": "0:05:27",
            "end": "0:05:30",
            "text": "\u0924\u094b \u090f\u0938\u0947 \u0938\u094b\u0939\u093e \u0936\u0940\u0930 \u0938\u0940\u0902\u0917 \u0930\u094b\u0917\u093e \u0930\u0939\u0947\u0917\u093e\u0964"
        },
        {
            "start": "0:05:46",
            "end": "0:05:47",
            "text": "\u092e\u0948\u0926\u0928 \u0915\u0941\u0932 Mistress"
        },
        {
            "start": "0:06:09",
            "end": "0:06:10",
            "text": "\u0905\u0928 \u092f\u094b\u0930 \u092e\u093e\u0925"
        },
        {
            "start": "0:06:10",
            "end": "0:06:13",
            "text": "\u091c\u090f\u0921\u093c"
        },
        {
            "start": "0:06:17",
            "end": "0:06:18",
            "text": "\u0936\u0947\u091c"
        },
        {
            "start": "0:06:40",
            "end": "0:06:44",
            "text": "\u0906\u092c \u0935\u0906\u092c \u0914\u0930 \u092c\u0935\u093e\u0903\u093e\u0925\u0947 \u0939\u0948\u0964"
        },
        {
            "start": "0:06:44",
            "end": "0:06:50",
            "text": "\u0905\u0930\u094d\u091a\u094b\u0932\u0947\u0902\u0940 \u0905\u0930\u094d\u0935\u093e\u0932\u093e \u0915\u094d\u0926\u094b\u092c\u0940\u0908\u0903"
        },
        {
            "start": "0:06:50",
            "end": "0:06:52",
            "text": "\u0905\u0930\u094d\u0935\u093e\u0932\u093e \u0905\u092a\u094d\u0926\u094b\u092c\u0940\u0903"
        },
        {
            "start": "0:07:10",
            "end": "0:07:14",
            "text": "\u0935\u093e\u0908 \u0936\u093e\u0932\u093e \u091c\u093f\u090f! \u0935\u093e\u0908 \u091a\u093e\u0926\u0947! \u0935\u093e\u0908 \u092d\u093e\u0908 \u092d\u093e\u0908 \u0935\u093e\u0908 \u091a\u093e\u091a\u0940!"
