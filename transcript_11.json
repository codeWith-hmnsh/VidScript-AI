    ],
    "plain_text": "[0:00:00] \u092f\u0947 \u0915\u094b\u091f \u0915\u093f\u0924\u0947 \u092e\u093f\u0932\u0924\u093e \u0939\u0948 \u091c\u0940?\n[0:00:03] \u0915\u094d\u092f\u094b\u0902?\n[0:00:04] \u091c\u0947 \u0926\u0947\u0916 \u0930\u0939\u0941\u0902, \u0915\u094b\u091f \u092a\u0948\u0928\u0947 \u0935\u093e\u0932\u0947 \u0915\u094b\u0908\u091c\u093c\u093e \u091c\u093e\u0926\u093e \u092e\u093f\u0932 \u0930\u0939\u0940 \u0939\u0948.\n[0:00:07] \u092e\u0948\u0902 \u092d\u0940 \u092a\u0948\u0928\u0941\u0917\u093e.\n[0:00:09] \u0905\u091a \u0905\u091a, \u0905\u0916 \u0915\u094b\u091f \u092a\u0948\u0928 \u0930\u0939\u0947 \u0939\u0948\u0902.\n[0:00:11] \u091c\u0940.\n[0:00:12] \u092a\u0939\u0932\u0947 \u092f\u0947 \u092a\u0924\u093e \u0939\u0948, \u0905\u092c \u0939\u0948 \u0915\u094b\u0902?\n[0:00:14] \u091c\u0935\u093e\u0928 \u092e\u093f\u0932\u0915\u093e \u0938\u093f\u0902\u0917, \u092f\u0947 \u092e\u0940 \u0938\u0902\u091f\u0930\u0938 \u0915\u0902\u0926\u094d\u0930\u093e \u092c\u093e\u0926.\n[0:00:17] \u0905\u091a \u0906\u0916.\n[0:00:31] \u092f\u0947 \u092f\u0947 \u0905\u092c \u0932\u0947\u091c\u093c\u093e \u0930\u0939\u0947 \u0939\u0948\u0902, \u0939\u0948 \u0928\u093e?\n[0:00:35] \u0938\u092c \u0915\u094b \u0928\u0939\u0940\u0902 \u092e\u093f\u0932\u0924\u093e \u0939\u0948.\n[0:00:37] \u0939\u092e\u0930\u0947 \u091c\u093e\u0938\u0947 \u0915\u0941\u091f \u091a\u093e\u092e\u092a\u093f\u092f\u0902\u091c \u0915\u094b \u092e\u093f\u0932\u0924\u093e \u0939\u0948.\n[0:00:41] \u0924\u0940\u0915 \u0939\u0948?\n[0:00:43] \u091a\u0932\u093f, \u091c\u093e\u090f.\n[0:00:46] \u092c\u093e\u0917\u093f\u090f?\n[0:00:49] \u091a\u0932\u093f, \u0932\u093f\u0915\u0932 \u092f\u0939\u093e \u0938\u0947.\n[0:00:53] \u091a\u094b\u0932\u094b, \u0924\u0947\u0930\u0947 \u0915\u0930\u094b.\n[0:00:55] \u091a\u094b\u0932\u0924\u0947 \u0938\u0947.\n[0:01:00] \u092c\u093e\u0917\u093f\u090f, \u0930\u0939\u093e \u092c\u093e\u0917\u093f\u090f.\n[0:02:00] \u0905\u0908, \u092f\u0947 \u0915\u094d\u092f\u093e \u0926\u0947\u0916 \u0930\u0939\u0947 \u0938\u093e \u0932\u0947, \u0935\u093f\u0938\u094d\u092e\u093e\u0930\u094d\u091f \u0938\u0926\u093e\u0930 \u091c\u0940,\n[0:02:17] \u092e\u093f\u0932\u0915\u094d\u092f\u093e \u092e\u0928\u094d\u0917\u0947 \u0905\u0926\u094d\u092f\u093e, \u092e\u093f\u0932\u0915\u094d\u092f\u093e \u092e\u0928\u094d\u0917\u093e \u091a\u0902\u092a\u094d\u092f\u0928,\n[0:02:24] \u0905\u0908, \u091a\u0902\u092a\u094d\u092f\u0928 \u092e\u093f\u0932\u0915\u093e \u0938\u0940\u0902 \u0930\u0939\u093e \u091c\u0940?\n[0:02:33] \u0915\u094d\u092f\u093e \u0939\u0948?\n[0:02:36] \u091a\u094b\u0930 \u0926\u0932\u093f\u0928 \u0924\u0930 \u0938\u093e\u0932\u0947, \u091a\u094b\u0930\u0940 \u0915\u0930 \u0930\u0939\u0947?\n[0:02:39] \u0935\u0942\u0928\u093e\u0908 \u091c\u0940, \u092e\u0948\u0902\u091f\u0947 \u0938\u092d \u092a\u094d\u092f\u0928\u0915\u0947 \u0924\u0947\u0916\u0930\u093e \u0925\u093e \u091c\u0940,\n[0:02:42] \u092a\u094d\u092f\u0928\u0915\u0947 \u0926\u0947\u0916\u0930\u093e \u0926\u094d\u092f\u093e\u0928, \u092c\u094d\u092f\u0928\u0915\u0947.\n[0:02:45] \u091a\u094b\u0930 \u0938\u093e\u0932\u0947, \u0935\u094b\u0908, \u092e\u0941\u091c\u093c \u091a\u094b\u0930\u0928\u093e \u092c\u094b\u0932\u094b,\n[0:02:50] \u091a\u094b\u0930 \u0928\u0940 \u0924\u094b \u0914\u0930 \u0915\u094d\u092f\u093e \u0939\u0948?\n[0:03:21] \u091c\u094b\u093c\u093e!\n[0:03:25] \u091c\u094b\u0930 \u092e\u0947\u0902 \u092f\u094b!\n[0:03:27] \u0935\u094b\u0921!\n[0:03:28] \u0935\u0921\u093c!\n[0:03:30] \u0935\u0921\u093c!\n[0:03:31] \u0935\u0921\u093c!\n[0:03:38] \u0935\u0921\u093c!\n[0:03:41] \u0935\u0921\u093c!\n[0:03:42] \u0935\u0921\u093c!\n[0:03:43] \u091c\u094b\u093c\u094b!\n[0:03:44] \u092a\u093e\u0926\u0930\u093e\u0935!\n[0:03:45] \u091c\u094b\u0930\u0940 \u0915\u0930 \u0930\u093e\u092c \u092d\u093e \u0932\u0917\u0915\u093e!\n[0:03:46] \u091c\u094b\u0930\u0940 \u0928\u0939\u0940\u0902 \u0917\u0940\u0924\u0940!\n[0:03:47] \u091c\u094b\u0921 \u0915\u093e \u0924